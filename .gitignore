# Package files
*.egg-info/
.eggs/

# Personal files
TASKS.md
MEMORY.md
.claude/worktrees/

# Cron and operational logs (content gitignored; directory tracked via .gitkeep)
logs/*.log
tmp/
.claude/settings.local.json

# News-digest runtime state (ledger + FactSet result cache + verdict cache — regenerated each run)
state/news_digest_seen.jsonl
state/factset_cache/
state/news_verdict_cache_*.json
logs/news_digest_*.txt
# v3 news-flow brief section for combine_and_send (ephemeral daily)
logs/report_news_*.txt

# Chunk store — embeddings + caches + DERIVED metrics are regenerable; ignore the
# dir's contents but TRACK state/chunk_store/factset_raw/ (Store B source-of-truth:
# the FactSet guidance+surprise pulls, not regenerable without MCP access).
state/chunk_store/*
!state/chunk_store/factset_raw/
# (metrics.jsonl / credibility.json are direct children of chunk_store/, so they stay
#  ignored by the `*` rule above — derived from factset_raw via ingest_metrics.py)

# v3 ingest runtime state (watermark — regenerable via DB rescan)
state/v3_ingest/

# Obsidian per-device workspace state (don't sync between devices)
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/workspace-tablet.json
.obsidian/cache
.obsidian/.cache

# Prevent future iPad/Obsidian noise from being committed
.obsidian/plugins/
.obsidian/community-plugins.json
.obsidian/graph.json
Untitled*.md
Untitled*.canvas
Untitled*.base

.obsidian/
